  <!-- Recreación fiel de Destiny App a partir de su código real:
       Colors.kt (#121212, #9C27B0, #2196F3), Gradients.kt (DestinyPrimary,
       SunsetMars), Cards.kt (DestinyHeroCard, DestinyDetailedEventCard) y
       Navigation.kt (barra flotante glass, 5 destinos). -->
  <symbol id="wf-destiny" viewBox="0 0 200 400">
    <defs>
      <linearGradient id="destinyPrimary" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#9333EA"/>
        <stop offset="1" stop-color="#2563EB"/>
      </linearGradient>
      <linearGradient id="destinySunset" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#F97316" stop-opacity="0.55"/>
        <stop offset="1" stop-color="#DC2626" stop-opacity="0.15"/>
      </linearGradient>
    </defs>

    <rect x="0" y="0" width="200" height="400" fill="#121212"/>
    <text x="16" y="32" font-size="15" font-weight="800" fill="#FFFFFF">Para ti</text>

    <!-- Hero card (DestinyHeroCard) -->
    <rect x="16" y="46" width="168" height="180" rx="16" fill="url(#destinyPrimary)"/>
    <rect x="28" y="134" width="66" height="18" rx="9" fill="#FFFFFF" fill-opacity="0.15" stroke="#FFFFFF" stroke-opacity="0.2"/>
    <circle cx="37" cy="143" r="3.4" fill="#FF9800"/>
    <text x="45" y="146" font-size="7.5" font-weight="700" fill="#FFFFFF">Trending</text>
    <text x="28" y="168" font-size="14" font-weight="800" fill="#FFFFFF">NEON NIGHTS</text>
    <text x="28" y="184" font-size="14" font-weight="800" fill="#FFFFFF">FESTIVAL</text>
    <text x="28" y="199" font-size="7" fill="#EEEEEE">Querétaro, Qro. · Techno · Outdoor</text>
    <rect x="28" y="207" width="108" height="22" rx="11" fill="url(#destinyPrimary)" stroke="#FFFFFF" stroke-opacity="0.25"/>
    <text x="82" y="221" font-size="8" font-weight="700" fill="#FFFFFF" text-anchor="middle">Ver Detalles →</text>

    <!-- Segunda tarjeta (DestinyDetailedEventCard) asomando -->
    <rect x="16" y="238" width="168" height="72" rx="16" fill="#1E1E1E"/>
    <rect x="16" y="238" width="168" height="38" rx="16" fill="url(#destinySunset)"/>
    <rect x="26" y="246" width="70" height="15" rx="7" fill="#000000" fill-opacity="0.6"/>
    <text x="32" y="256" font-size="6.5" font-weight="700" fill="#FFFFFF">Electrónica</text>
    <text x="26" y="292" font-size="11" font-weight="800" fill="#FFFFFF">Sunset Rooftop</text>
    <text x="26" y="303" font-size="7" fill="#757575">24 Oct · Desde $450 MXN</text>

    <!-- Barra de navegación flotante glass (DestinyBottomBar) -->
    <rect x="16" y="358" width="168" height="30" rx="15" fill="#000000" fill-opacity="0.8" stroke="#FFFFFF" stroke-opacity="0.2"/>
    <circle cx="43" cy="373" r="11" fill="#9C27B0" fill-opacity="0.25"/>
    <path d="M38 376v-6l5-4 5 4v6h-3v-4h-4v4z" fill="#CE93D8"/>
