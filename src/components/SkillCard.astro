---
interface Props {
  skill: {
    id: string;
    title: string;
    title_en?: string;
    tags: string[];
  };
}

const { skill } = Astro.props;
---

<div class="skill-card">
  <h3 data-en={skill.title_en}>{skill.title}</h3>
  <div class="tags">
    {skill.tags.map(tag => (
      <span>{tag}</span>
    ))}
  </div>
</div>
