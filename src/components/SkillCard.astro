---
interface Props {
  skill: {
    id: string;
    title: string;
    tags: string[];
  };
}

const { skill } = Astro.props;
---

<div class="skill-card">
  <h3>{skill.title}</h3>
  <div class="tags">
    {skill.tags.map(tag => (
      <span>{tag}</span>
    ))}
  </div>
</div>

<style is:global>
  /* Styles are in styles.css */
</style>
