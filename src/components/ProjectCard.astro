---
interface Props {
  project: {
    id: string;
    category: string;
    title: string;
    featured?: boolean;
    badge?: {
      type: string;
      text: string;
      href?: string;
    };
    caseStudy?: {
      problem: string;
      solution: string;
      result: string;
    };
    features?: string[];
    tags?: string[];
  };
}

const { project } = Astro.props;
---

<article class={`project-card reveal ${project.featured ? 'featured' : ''}`}>
  <div class="project-top">
    <span class="project-cat">{project.category}</span>
    {project.badge && (
      project.badge.type === 'private' ? (
        <span class="project-badge badge-private">{project.badge.text}</span>
      ) : (
        <a href={project.badge.href} target="_blank" rel="noopener" class="project-badge badge-link">
          {project.badge.text}
        </a>
      )
    )}
  </div>
  <h3>{project.title}</h3>
  
  {project.caseStudy && (
    <div class="case">
      <div class="case-row">
        <span class="case-label">Problema</span>
        <p>{project.caseStudy.problem}</p>
      </div>
      <div class="case-row">
        <span class="case-label">Solución</span>
        <p>{project.caseStudy.solution}</p>
      </div>
      <div class="case-row">
        <span class="case-label">Resultado</span>
        <p>{project.caseStudy.result}</p>
      </div>
    </div>
  )}

  {project.features && project.features.length > 0 && (
    <ul class="features">
      {project.features.map(feature => (
        <li>{feature}</li>
      ))}
    </ul>
  )}

  {project.tags && project.tags.length > 0 && (
    <div class="tags">
      {project.tags.map(tag => (
        <span>{tag}</span>
      ))}
    </div>
  )}
</article>
