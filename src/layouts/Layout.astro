---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Javier Sánchez (Javas) — Desarrollador Full-Stack & Mobile",
  description = "Portafolio de Javier Sánchez (Javas): desarrollador Full-Stack, iOS y Android en Querétaro, México. Proyectos en Swift, Kotlin, .NET, Node.js y más.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Open Graph Meta Tags -->
  <meta property="og:title" content="Javier Sánchez (Javas) — Full-Stack & Mobile Developer">
  <meta property="og:description" content="Construyo productos digitales completos: iOS, Android & Web. Full-stack desde arquitectura hasta UI.">
  <meta property="og:image" content="https://notjavas.github.io/og-banner.svg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Javas - Full-Stack & Mobile Developer">
  <meta property="og:url" content="https://notjavas.github.io">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="es_MX">

  <!-- Twitter Card Meta Tags -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Javier Sánchez (Javas) — Full-Stack & Mobile Developer">
  <meta name="twitter:description" content="Construyo productos digitales completos: iOS, Android & Web. Full-stack desde arquitectura hasta UI.">
  <meta name="twitter:image" content="https://notjavas.github.io/og-banner.svg">

  <link rel="icon" href="data:,">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">

  <!-- Theme detection (blocks FOUC) -->
  <script>
    (function() {
      const savedTheme = localStorage.getItem('theme');
      if (savedTheme === 'light') {
        document.documentElement.dataset.theme = 'light';
      }
    })();
  </script>

  <!-- Plausible Analytics -->
  <script defer data-domain="notjavas.github.io" src="https://plausible.io/js/script.events.js"></script>
</head>
<body>

  <slot />

  <script type="text/javascript" src="/script.js"></script>
</body>
</html>
