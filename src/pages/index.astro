---
import Layout from '../layouts/Layout.astro';
import Sprite from '../components/Sprite.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PricingCard from '../components/PricingCard.astro';
import ComboCard from '../components/ComboCard.astro';
import SkillCard from '../components/SkillCard.astro';

import projects from '../data/projects.json';
import pricing from '../data/pricing.json';
import combos from '../data/combos.json';
import skills from '../data/skills.json';
---

<Layout>
  <div class="bg-glow" aria-hidden="true"></div>

  <header class="nav" id="nav">
    <div class="nav-inner">
      <a href="#top" class="logo">Javier Sánchez<span class="dot">.</span></a>
      <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" data-aria-en="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
      <nav class="nav-links" id="navLinks">
        <a href="#about" data-en="About">Sobre mí</a>
        <a href="#projects" data-en="Projects">Proyectos</a>
        <a href="#capturas" data-en="Screenshots">Capturas</a>
        <a href="#pricing" data-en="Pricing">Precios</a>
        <a href="#roadmap" data-en="Process">Proceso</a>
        <a href="#contact" class="nav-cta" data-en="Contact">Contacto</a>
        <button class="theme-toggle" id="themeToggle" aria-label="Cambiar entre modo día y modo noche" data-aria-en="Switch between day and night mode">
          <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4.5"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.5 4.5l2 2M17.5 17.5l2 2M19.5 4.5l-2 2M6.5 17.5l-2 2"/></svg>
          <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 14.5A8.5 8.5 0 0 1 9.5 4 8.5 8.5 0 1 0 20 14.5z"/></svg>
        </button>
        <button class="lang-toggle" id="langToggle" aria-label="Cambiar a inglés">
          <span class="to-en">EN</span>
          <span class="to-es">ES</span>
        </button>
      </nav>
    </div>
  </header>

  <main>

    <section class="hero" id="top">
      <div class="hero-content">
        <p class="eyebrow reveal" data-en="Available for freelance projects">Disponible para proyectos freelance</p>
        <h1 class="reveal">
          <span data-en="I build digital products">Construyo productos digitales</span><br>
          <span data-en="end-to-end —">de punta a punta —</span> <span class="grad-text">iOS, Android &amp; Web</span>
        </h1>
        <p class="hero-sub reveal">
          <span data-en="I'm">Soy</span> <strong>Javier Sánchez</strong><span data-en=", a full-stack and mobile developer based in Querétaro, Mexico. I design and build complete apps and platforms: from planning, through architecture and backend services, to the last animation in the interface.">, desarrollador full-stack y mobile en Querétaro, México.
          Diseño e implemento apps y plataformas completas: desde la planeación, pasando por la
          arquitectura y los servicios, hasta la última animación de la interfaz.</span>
        </p>
        <div class="hero-actions reveal">
          <a href="#projects" class="btn btn-primary" data-en="View projects">Ver proyectos</a>
          <a href="#contact" class="btn btn-ghost" data-en="Contact">Contactar</a>
        </div>
        <div class="hero-social reveal">
          <a href="https://github.com/NotJavas" target="_blank" rel="noopener" aria-label="GitHub">
            <svg width="20" height="20" viewBox="0 0 24 24"><use href="#icon-gh"/></svg>
          </a>
          <a href="#contact" class="mailto" data-u="javierfsanvaz" data-d="hotmail.com" aria-label="Email">
            <svg width="20" height="20" viewBox="0 0 24 24"><use href="#icon-mail"/></svg>
          </a>
          <a href="https://wa.me/524425943653" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg width="20" height="20" viewBox="0 0 24 24"><use href="#icon-wa"/></svg>
          </a>
        </div>
      </div>

      <div class="hero-stats reveal">
        <div class="stat"><span class="stat-num" data-count="9">9</span><span class="stat-label" data-en="Featured projects">Proyectos destacados</span></div>
        <div class="stat"><span class="stat-num" data-count="3">3</span><span class="stat-label" data-en="Platforms — iOS · Android · Web">Plataformas — iOS · Android · Web</span></div>
        <div class="stat"><span class="stat-num" data-count="100" data-suffix="%">100%</span><span class="stat-label" data-en="Full-stack, from design to production">Full-stack, del diseño a producción</span></div>
      </div>
    </section>

    <section class="about" id="about">
      <div class="section-head reveal">
        <p class="section-tag" data-en="About me">Sobre mí</p>
        <h2><span data-en="I like building">Me gusta construir</span> <span class="hl" data-en="complete projects">proyectos completos</span> <span data-en="and doing it right">y bien hechos</span></h2>
      </div>
      <p class="about-text reveal" data-en="My name is Javier Sánchez, I study at the Universidad Autónoma de Querétaro, and I'm a freelance developer. It's just me — answering my own emails and putting my name on every project I deliver. I do this because I want to build a real career doing what I'm good at, and because I genuinely like it when something I coded helps someone.">
        Mi nombre es Javier Sánchez, estudio en la Universidad Autónoma de Querétaro y soy
        desarrollador freelance. Soy yo, respondiendo mis propios correos y poniendo mi nombre en cada
        proyecto que entrego. Hago esto porque quiero construirme una buena carrera con lo que sé
        hacer, y porque me gusta cuando algo que programé genuinamente ayuda a alguien.
      </p>
      <p class="about-text reveal" data-en="I work across every layer of a product: native interfaces in SwiftUI and Jetpack Compose, backends in .NET and Node.js, relational databases, and more. I care about understanding the whole problem and adding real value to your product, designing architectures that can be maintained and grow with your needs.">
        Trabajo en todas las capas de un producto: interfaces nativas en SwiftUI y Jetpack Compose,
        backends en .NET y Node.js, bases de datos relacionales, etc.
        Me interesa entender el problema completo y añadirle un plus a tu producto,
        diseñando arquitecturas que se puedan mantener y crecer conforme a tus necesidades.
      </p>
      <div class="trust-row reveal">
        <div class="trust-item" data-en="Direct communication with me, no middlemen">Trato directo conmigo, sin intermediarios</div>
        <div class="trust-item" data-en="Public, verifiable code">Código público y verificable</div>
        <div class="trust-item" data-en="I personally respond within 24 hours">Respondo personalmente en menos de 24 horas</div>
      </div>
    </section>

    <section class="skills" id="skills">
      <div class="section-head reveal">
        <p class="section-tag" data-en="Stack &amp; tools">Stack &amp; herramientas</p>
        <h2><span data-en="What I">Con qué</span> <span class="hl" data-en="build with">construyo</span></h2>
      </div>
      <div class="skills-grid reveal">
        {skills.map(skill => (
          <SkillCard skill={skill} />
        ))}
      </div>
    </section>

    <section class="projects" id="projects">
      <div class="section-head reveal">
        <p class="section-tag" data-en="Featured projects">Proyectos destacados</p>
        <h2><span data-en="Work that shows">Trabajo que muestra</span> <span class="hl" data-en="how I think">cómo pienso</span></h2>
      </div>

      <div class="projects-grid">
        {projects.map(project => (
          <ProjectCard project={project} />
        ))}

        <article class="project-card reveal cta-card">
          <h3 data-en="Your project here?">¿Tu proyecto aquí?</h3>
          <p data-en="Tell me what you need and let's make it the next project on this list.">Cuéntame qué necesitas y lo convertimos en el siguiente proyecto en esta lista.</p>
          <a href="https://wa.me/524425943653" target="_blank" rel="noopener" class="btn btn-primary" data-en="Let's chat on WhatsApp">Platicamos por WhatsApp</a>
        </article>
      </div>
    </section>

    <section class="shots" id="capturas">
      <div class="section-head reveal">
        <p class="section-tag" data-en="On screen">En pantalla</p>
        <h2><span data-en="This is what">Así se ven</span> <span class="hl" data-en="my projects look like">mis proyectos</span></h2>
        <p class="pricing-sub" data-en="Real screenshots wherever I can share them — the rest are faithful recreations of the real design. Want to see them running? Ask me for a live demo — it's free and no strings attached.">
          Capturas reales donde puedo mostrarlas — el resto son recreaciones fieles al diseño real.
          ¿Quieres verlas funcionando? Pídeme un demo en vivo — es gratis y sin compromiso.
        </p>
      </div>

      <div class="shots-groups">

        <div class="shot-group reveal">
          <div class="shot-group-label">
            <span class="shot-group-num">01</span>
            <h3>MONEI</h3>
            <p data-en="Personal finance management — iOS">Gestión financiera personal — iOS</p>
          </div>
          <div class="shot-group-pieces">
            <figure class="shot-piece">
              <div class="device phone">
                <div class="device-notch"></div>
                <img src="/img/monei-home.jpg" alt="Captura real del inicio de MONEI, con patrimonio total y cuentas" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece">
              <div class="device phone">
                <div class="device-notch"></div>
                <img src="/img/monei-analysis.jpg" alt="Captura real del desglose de gastos por categoría en MONEI" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece">
              <div class="device phone">
                <div class="device-notch"></div>
                <img src="/img/monei-subscription.jpg" alt="Captura real de los planes de suscripción en MONEI" loading="lazy" />
              </div>
            </figure>
          </div>
        </div>

        <div class="shot-group accent-2 reverse reveal">
          <div class="shot-group-label">
            <span class="shot-group-num">02</span>
            <h3>Defiants</h3>
            <p data-en="Tournament platform — Full-Stack Web">Plataforma de torneos — Full-Stack Web</p>
          </div>
          <div class="shot-group-pieces">
            <figure class="shot-piece piece-wide">
              <div class="device browser">
                <div class="browser-bar"><span></span><span></span><span></span></div>
                <img src="/img/defiants-tournaments.png" alt="Captura real del listado de torneos en Defiants, corriendo en local" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece piece-wide">
              <div class="device browser">
                <div class="browser-bar"><span></span><span></span><span></span></div>
                <img src="/img/defiants-bracket.png" alt="Captura real del bracket de torneo en Defiants, corriendo en local" loading="lazy" />
              </div>
            </figure>
          </div>
        </div>

        <div class="shot-group reveal">
          <div class="shot-group-label">
            <span class="shot-group-num">03</span>
            <h3>Destiny</h3>
            <p data-en="Local events on a map — Android">Eventos locales en un mapa — Android</p>
          </div>
          <div class="shot-group-pieces">
            <figure class="shot-piece">
              <div class="device phone">
                <div class="device-notch"></div>
                <img src="/img/destiny-notifications.png" alt="Captura real de la pantalla de notificaciones de Destiny App" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece">
              <div class="device phone">
                <div class="device-notch"></div>
                <img src="/img/destiny-profile.png" alt="Captura real de la pantalla de perfil e intereses de Destiny App" loading="lazy" />
              </div>
            </figure>
          </div>
        </div>

        <div class="shot-group accent-2 reverse reveal">
          <div class="shot-group-label">
            <span class="shot-group-num">04</span>
            <h3 data-en="Missing Persons">Personas Desaparecidas</h3>
            <p data-en="Analysis dashboard — Data Science">Dashboard de análisis — Data Science</p>
          </div>
          <div class="shot-group-pieces">
            <figure class="shot-piece piece-wide">
              <div class="device browser">
                <div class="browser-bar"><span></span><span></span><span></span></div>
                <img src="/img/desaparecidos-dashboard.png" alt="Captura real del dashboard de análisis de personas desaparecidas" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece shot-chip">
              <strong>1960–2024</strong>
              <span data-en="Historical trend, thousands of records">Serie histórica, miles de registros</span>
            </figure>
          </div>
        </div>

        <div class="shot-group reveal">
          <div class="shot-group-label">
            <span class="shot-group-num">05</span>
            <h3>Centinel</h3>
            <p data-en="Road risk by segment — Data Science">Riesgo vial por tramo — Data Science</p>
          </div>
          <div class="shot-group-pieces">
            <figure class="shot-piece piece-wide">
              <div class="device browser">
                <div class="browser-bar"><span></span><span></span><span></span></div>
                <img src="/img/centinel-riesgo.png" alt="Captura real del mapa de riesgo vial de Centinel" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece shot-chip">
              <strong data-en="Graph">Grafo</strong>
              <span data-en="Road network modeled as nodes and edges">Red vial modelada como nodos y aristas</span>
            </figure>
          </div>
        </div>

        <div class="shot-group accent-2 reverse reveal">
          <div class="shot-group-label">
            <span class="shot-group-num">06</span>
            <h3>Titanic</h3>
            <p data-en="Survival prediction — Machine Learning">Predicción de supervivencia — Machine Learning</p>
          </div>
          <div class="shot-group-pieces">
            <figure class="shot-piece piece-wide">
              <div class="device browser">
                <div class="browser-bar"><span></span><span></span><span></span></div>
                <img src="/img/titanic-eda.png" alt="Captura real del análisis exploratorio y modelos del proyecto Titanic" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece shot-chip">
              <strong>~83%</strong>
              <span data-en="Accuracy — SVM, 5 models compared">Accuracy — SVM, 5 modelos comparados</span>
            </figure>
          </div>
        </div>

        <div class="shot-group reveal">
          <div class="shot-group-label">
            <span class="shot-group-num">07</span>
            <h3>Melts</h3>
            <p data-en="Landing page with original branding — Web">Landing page con marca propia — Web</p>
          </div>
          <div class="shot-group-pieces">
            <figure class="shot-piece piece-wide">
              <div class="device browser">
                <div class="browser-bar"><span></span><span></span><span></span></div>
                <img src="/img/melts-hero.jpg" alt="Captura real de la landing page de Melts" loading="lazy" />
              </div>
            </figure>
            <figure class="shot-piece shot-chip">
              <strong data-en="100% original">100% propia</strong>
              <span data-en="Brand, tone of voice and copywriting">Marca, tono de voz y copywriting</span>
            </figure>
          </div>
        </div>

      </div>
    </section>

    <section class="pricing" id="pricing">
      <div class="section-head reveal">
        <p class="section-tag" data-en="Pricing">Precios</p>
        <h2><span data-en="">¿</span><span class="hl" data-en="How much does it cost">Cuánto cuesta</span> <span data-en="to work with me?">trabajar conmigo?</span></h2>
        <p class="pricing-sub" data-en="You don't need to know anything about technology to work with me — just tell me what problem you want to solve. These are starting points; every project is quoted based on what you actually need.">
          No necesitas saber de tecnología para trabajar conmigo — solo contarme qué problema quieres
          resolver. Estos son puntos de partida; cada proyecto se cotiza según lo que realmente necesites.
        </p>
        <span class="first-time-badge" data-en="-20% off your first project with me">-20% en tu primer proyecto conmigo</span>
      </div>

      <div class="pricing-grid">
        {pricing.map(pkg => (
          <PricingCard pricing={pkg} />
        ))}
      </div>

      <div class="section-head reveal combo-head">
        <p class="section-tag" data-en="Combine and save">Combina y ahorra</p>
        <h2><span data-en="Need more than one?">¿Necesitas más de uno?</span> <span class="hl" data-en="It's cheaper">Sale más barato</span> <span data-en="together">junto</span></h2>
        <p class="pricing-sub" data-en="When one project combines several of these services, design, planning and setup get shared — and I pass that savings on to you.">
          Si un mismo proyecto combina varios de estos servicios, se comparte diseño, planeación y
          configuración — y ese ahorro te lo paso a ti.
        </p>
      </div>

      <div class="combo-grid">
        {combos.filter(combo => !combo.featured).map(combo => (
          <ComboCard combo={combo} />
        ))}
      </div>

      {combos.filter(combo => combo.featured).map(combo => (
        <div class="featured-combo-wrap reveal">
          <div class="combo-callout combo-callout-left">
            <span data-en="Best savings">El mejor ahorro</span>
            <svg class="combo-arrow" viewBox="0 0 100 80" aria-hidden="true">
              <path d="M8 12 C 35 4, 65 20, 84 56" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M70 50 L86 58 L74 68" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>

          <ComboCard combo={combo} />

          <div class="combo-callout combo-callout-right">
            <svg class="combo-arrow combo-arrow-flip" viewBox="0 0 100 80" aria-hidden="true">
              <path d="M8 12 C 35 4, 65 20, 84 56" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
              <path d="M70 50 L86 58 L74 68" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span data-en="Everything in one package">Todo en un solo paquete</span>
          </div>
        </div>
      ))}

      <p class="pricing-note reveal" data-en="Final prices depend on the size and details of the project — message me and let's talk, no strings attached, before any formal quote. The first-project discount and the bundle discounts don't stack: whichever works better for you applies.">
        Los precios finales dependen del tamaño y los detalles del proyecto — escríbeme y platicamos sin
        compromiso antes de cualquier cotización formal. El descuento de primer proyecto y los descuentos
        por combinar servicios no se acumulan entre sí: aplica el que más te convenga.
      </p>
    </section>

    <section class="roadmap" id="roadmap">
      <div class="section-head reveal">
        <p class="section-tag" data-en="How we work">Cómo trabajamos</p>
        <h2><span data-en="From the first chat to">De la primera plática a</span> <span class="hl" data-en="your project up and running">tu proyecto funcionando</span></h2>
        <p class="pricing-sub" data-en="A clear process, with room for adjustments along the way — not a black box.">
          Un proceso claro, con espacio para ajustes en el camino — no una caja negra.
        </p>
      </div>

      <ol class="roadmap-list">
        <li class="roadmap-step reveal">
          <span class="roadmap-num">1</span>
          <div class="roadmap-content">
            <h3 data-en="Free initial chat">Plática inicial, sin costo</h3>
            <p data-en="You tell me what you need and we figure out together if I'm the right fit for your project — no strings attached.">Me cuentas qué necesitas y evaluamos juntos si soy el fit correcto para tu proyecto — sin compromiso.</p>
          </div>
        </li>
        <li class="roadmap-step reveal">
          <span class="roadmap-num">2</span>
          <div class="roadmap-content">
            <h3 data-en="Written proposal">Propuesta por escrito</h3>
            <p data-en="You get clear scope, timeline, and price before we start. No surprises halfway through.">Recibes alcance, tiempo estimado y precio claros antes de empezar. Nada de sorpresas a la mitad.</p>
          </div>
        </li>
        <li class="roadmap-step reveal">
          <span class="roadmap-num">3</span>
          <div class="roadmap-content">
            <h3 data-en="Design before code">Diseño antes que código</h3>
            <p data-en="We validate together how your project will look and feel. Adjusting a mockup takes minutes; adjusting code that's already built takes hours.">Validamos juntos cómo se va a ver y sentir tu proyecto. Ajustar un mockup toma minutos; ajustar código ya hecho toma horas.</p>
          </div>
        </li>
        <li class="roadmap-step reveal">
          <span class="roadmap-num">4</span>
          <div class="roadmap-content">
            <h3 data-en="Development with real progress">Desarrollo con avances</h3>
            <p data-en="I build in stages and show you real progress along the way — not one generic deliverable at the end.">Construyo por partes y te muestro el progreso real en el camino — no un solo entregable genérico al final.</p>
          </div>
        </li>
        <li class="roadmap-step reveal">
          <span class="roadmap-num">5</span>
          <div class="roadmap-content">
            <h3 data-en="2 rounds of adjustments included">2 rondas de ajustes incluidas</h3>
            <p data-en="After delivery you have the right to request changes — two rounds of adjustments at no extra cost to fine-tune the details.">Después de la entrega tienes derecho a pedir cambios — dos rondas de ajustes sin costo extra para afinar los detalles.</p>
          </div>
        </li>
        <li class="roadmap-step reveal">
          <span class="roadmap-num">6</span>
          <div class="roadmap-content">
            <h3 data-en="Delivery and support">Entrega y soporte</h3>
            <p data-en="I hand off your working project, with a 30-day support window to fix anything that comes up afterward.">Te dejo el proyecto funcionando, con una ventana de soporte de 30 días para resolver cualquier detalle que salga después.</p>
          </div>
        </li>
      </ol>
    </section>

    <section class="contact" id="contact">
      <div class="contact-box reveal">
        <h2><span data-en="Have">¿Tienes</span> <span class="hl" data-en="a project">un proyecto</span> <span data-en="in mind?">en mente?</span></h2>
        <p data-en="I'm available for freelance work — mobile apps, web platforms, or custom systems. Reach me however's easiest for you.">Estoy disponible para trabajos freelance — apps móviles, plataformas web o sistemas a medida.
           Escríbeme por donde te quede más cómodo.</p>
        <div class="hero-actions">
          <a href="https://wa.me/524425943653" target="_blank" rel="noopener" class="btn btn-primary">WhatsApp — 442 594 3653</a>
          <a href="#contact" class="btn btn-ghost mailto" data-u="javierfsanvaz" data-d="hotmail.com" data-show="1">Correo directo</a>
          <a href="https://github.com/NotJavas" target="_blank" rel="noopener" class="btn btn-ghost">GitHub — @NotJavas</a>
        </div>
        <p class="contact-alt"><span data-en="Prefer to call?">¿Prefieres llamar?</span> <a href="tel:+524425943653">442 594 3653</a></p>
      </div>
    </section>

  </main>

  <footer class="footer">
    <p><span data-en="Made by">Hecho por</span> Javier Sánchez (Javas) · Querétaro, México · <a href="https://wa.me/524425943653">442 594 3653</a> · <a href="#contact" class="mailto" data-u="javierfsanvaz" data-d="hotmail.com" data-show="1">correo</a></p>
  </footer>

  <Sprite />
</Layout>
